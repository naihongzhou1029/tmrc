{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "devops: setup",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/devops.ps1",
        "setup"
      ],
      "group": "none",
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "devops: build",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/devops.ps1",
        "build"
      ],
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": "$msCompile",
      "presentation": { "reveal": "silent", "panel": "shared" }
    },
    {
      "label": "devops: test",
      "type": "shell",
      "command": "powershell",
      "args": [
